# =============================================================================
# CDK Infrastructure
# =============================================================================

# CDK build output and synthesized CloudFormation templates
infrastructure/cdk.out/

# TypeScript compiled output
infrastructure/dist/

# Node dependencies
infrastructure/node_modules/

# CDK context — contains account ID and AZ lookups, regenerated on deploy.
# Commit this if you want reproducible deployments across machines;
# ignore it if you don't want account IDs in version control.
infrastructure/cdk.context.json

# CDK outputs written by --outputs-file flag (contains live resource IDs/ARNs)
cdk-outputs.json

# =============================================================================
# Lambda bundle — generated by bundle.sh before cdk deploy, not source code
# =============================================================================
infrastructure/lib/aoss-index-handler/bundle/

# =============================================================================
# Python (LangChain alternative)
# =============================================================================

# Virtual environments
langchain-alternative/.venv/
langchain-alternative/venv/
langchain-alternative/env/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# =============================================================================
# Secrets and environment files
# =============================================================================

# Local .env files (copy of .env.example with real values)
langchain-alternative/.env
.env
.env.local
.env.*.local

# AWS credentials — never commit these
.aws/credentials
.aws/config

# =============================================================================
# Kiro IDE / CLI settings
# =============================================================================

# MCP config may contain API keys or profile names — keep .env.example only
# Uncomment the line below if your mcp.json contains secrets:
# .kiro/settings/mcp.json

# =============================================================================
# OS and editor artifacts
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# JetBrains IDEs
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# =============================================================================
# Logs and temporary files
# =============================================================================
*.log
*.tmp
*.temp
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Security scan output (ASH) — large generated reports, not source
# =============================================================================
ash-output/
